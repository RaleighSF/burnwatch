    { "id": "storage", "name": "File storage", "unit": "GB", "ratePerUnit": 0.021, "ratePer": 1 },
    { "id": "edge_invocations", "name": "Edge function invocations", "unit": "invocation", "ratePerUnit": 2.00, "ratePer": 1000000 },
